set_global_assignment -name FAMILY "Cyclone IV E"
set_global_assignment -name DEVICE EP4CE10F17C8
set_global_assignment -name TOP_LEVEL_ENTITY top
set_global_assignment -name ORIGINAL_QUARTUS_VERSION 13.1
set_global_assignment -name PROJECT_CREATION_TIME_DATE "16:52:35  MARCH 10, 2026"
set_global_assignment -name LAST_QUARTUS_VERSION 13.1
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name MIN_CORE_JUNCTION_TEMP 0
set_global_assignment -name MAX_CORE_JUNCTION_TEMP 85
set_global_assignment -name ERROR_CHECK_FREQUENCY_DIVISOR 1
set_global_assignment -name NOMINAL_CORE_SUPPLY_VOLTAGE 1.2V
set_global_assignment -name STRATIX_DEVICE_IO_STANDARD "2.5 V"

# ===================================================
# 1. 时钟与复位
# ===================================================
set_location_assignment PIN_E1 -to clk_50m
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to clk_50m
set_location_assignment PIN_E15 -to rst_n
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to rst_n

# ===================================================
# 2. CH368 数据线 (P2排针 D0-D7)
# ===================================================
set_location_assignment PIN_M8 -to ch368_data[0]
set_location_assignment PIN_L8 -to ch368_data[1]
set_location_assignment PIN_L7 -to ch368_data[2]
set_location_assignment PIN_T6 -to ch368_data[3]
set_location_assignment PIN_R6 -to ch368_data[4]
set_location_assignment PIN_N8 -to ch368_data[5]
set_location_assignment PIN_P8 -to ch368_data[6]
set_location_assignment PIN_K9 -to ch368_data[7]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to ch368_data[*]

# ===================================================
# 3. CH368 地址线 (P2排针 A0-A7)
# ===================================================
set_location_assignment PIN_M9 -to ch368_addr[0]
set_location_assignment PIN_P9 -to ch368_addr[1]
set_location_assignment PIN_N9 -to ch368_addr[2]
set_location_assignment PIN_M10 -to ch368_addr[3]
set_location_assignment PIN_P11 -to ch368_addr[4]
set_location_assignment PIN_N11 -to ch368_addr[5]
set_location_assignment PIN_R7 -to ch368_addr[6]
set_location_assignment PIN_L10 -to ch368_addr[7]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to ch368_addr[*]

# ===================================================
# 4. CH368 控制线 (WR/RD/CS)
# ===================================================
set_location_assignment PIN_T9 -to ch368_wr_n
set_location_assignment PIN_T10 -to ch368_rd_n
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to ch368_wr_n
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to ch368_rd_n
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to ch368_cs_n

# ===================================================
# 5. 光源输出 (P3排针 8路)
# ===================================================
set_location_assignment PIN_A15 -to light_out[0]
set_location_assignment PIN_F11 -to light_out[1]
set_location_assignment PIN_A12 -to light_out[2]
set_location_assignment PIN_A10 -to light_out[3]
set_location_assignment PIN_D8 -to light_out[4]
set_location_assignment PIN_B6 -to light_out[5]
# 7#和8#光源暂时未定义，保留占位
set_location_assignment PIN_C8 -to light_out[6]
set_location_assignment PIN_D6 -to light_out[7]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to light_out[*]

# ===================================================
# 6. 相机输出 (P3排针 8路)
# ===================================================
set_location_assignment PIN_A14 -to camera_out[0]
set_location_assignment PIN_A13 -to camera_out[1]
set_location_assignment PIN_A11 -to camera_out[2]
set_location_assignment PIN_A9 -to camera_out[3]
set_location_assignment PIN_B7 -to camera_out[4]
set_location_assignment PIN_D11 -to camera_out[5]
# 7#和8#相机暂时未定义，保留占位
set_location_assignment PIN_C7 -to camera_out[6]
set_location_assignment PIN_D7 -to camera_out[7]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to camera_out[*]

# ===================================================
# 7. 气阀输出 (P3排针 4路)
# ===================================================
set_location_assignment PIN_E10 -to valve_out[0]
set_location_assignment PIN_D9 -to valve_out[1]
set_location_assignment PIN_F9 -to valve_out[2]
set_location_assignment PIN_E8 -to valve_out[3]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to valve_out[*]

# ===================================================
# 8. 电机控制
# ===================================================
set_location_assignment PIN_C6 -to motor_pwm_out
set_location_assignment PIN_D12 -to motor_en_out
# motor_dir_out 暂未在Excel中定义
set_location_assignment PIN_C12 -to motor_dir_out
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to motor_pwm_out
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to motor_en_out
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to motor_dir_out

# ===================================================
# 9. 编码器输入
# ===================================================
set_location_assignment PIN_E11 -to enc_a
set_location_assignment PIN_F6 -to enc_b
# enc_z 暂未定义
set_location_assignment PIN_F7 -to enc_z
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to enc_a
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to enc_b
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to enc_z

# ===================================================
# 10. 传感器输入
# ===================================================
set_location_assignment PIN_A7 -to sensor_in
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to sensor_in

# ===================================================
# 11. 三色灯控制 (LED红/黄/绿)
# ===================================================
set_location_assignment PIN_B11 -to w_misc_led_r
set_location_assignment PIN_B10 -to w_misc_led_y
set_location_assignment PIN_B9 -to w_misc_led_g
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to w_misc_led_r
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to w_misc_led_y
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to w_misc_led_g

# ===================================================
# 12. 蜂鸣器控制
# ===================================================
set_location_assignment PIN_C9 -to w_misc_buzzer
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to w_misc_buzzer

# ===================================================
# 13. 振动盘控制 (新增)
# ===================================================
set_location_assignment PIN_B13 -to vibrator_out
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to vibrator_out

# ===================================================
# 14. 下料控制 (新增)
# ===================================================
set_location_assignment PIN_B14 -to feeder_out
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to feeder_out

# ===================================================
# 6. 编译及文件设置
# ===================================================
set_global_assignment -name POWER_PRESET_COOLING_SOLUTION "23 MM HEAT SINK WITH 200 LFPM AIRFLOW"
set_global_assignment -name POWER_BOARD_THERMAL_MODEL "NONE (CONSERVATIVE)"
set_global_assignment -name PARTITION_NETLIST_TYPE SOURCE -section_id Top
set_global_assignment -name PARTITION_FITTER_PRESERVATION_LEVEL PLACEMENT_AND_ROUTING -section_id Top
set_global_assignment -name PARTITION_COLOR 16764057 -section_id Top

set_global_assignment -name VERILOG_FILE src/ch368_interface.v
set_global_assignment -name VERILOG_FILE src/workpiece_tracker.v
set_global_assignment -name VERILOG_FILE src/encoder.v
set_global_assignment -name VERILOG_FILE src/motor.v
set_global_assignment -name VERILOG_FILE src/top.v


# ===================================================
# 7. SignalTap 基本设置 (清理了报废的探针节点)
# ===================================================
set_global_assignment -name ENABLE_SIGNALTAP OFF
set_global_assignment -name USE_SIGNALTAP_FILE output_files/stp1.stp
set_global_assignment -name QIP_FILE ip/workpieces_ram.qip
set_global_assignment -name VERILOG_FILE src/cam_light_channel.v
set_global_assignment -name VERILOG_FILE src/valve_ctrl.v

set_global_assignment -name CDF_FILE output_files/Chain1.cdf
set_global_assignment -name CDF_FILE Chain5.cdf
set_global_assignment -name VERILOG_FILE src/misc_io_ctrl.v
set_instance_assignment -name PARTITION_HIERARCHY root_partition -to | -section_id Top